// ========== ADMIN SETTINGS PAGE ==========
function wpsm_register_settings() {
    add_option('wpsm_disable_feeds', 1);
    add_option('wpsm_hide_login', 1);
    add_option('wpsm_obfuscate_dirs', 1);
    add_option('wpsm_custom_login_slug', 'my-login');
    register_setting('wpsm_options_group', 'wpsm_disable_feeds');
    register_setting('wpsm_options_group', 'wpsm_hide_login');
    register_setting('wpsm_options_group', 'wpsm_obfuscate_dirs');
    register_setting('wpsm_options_group', 'wpsm_custom_login_slug');
}
add_action('admin_init', 'wpsm_register_settings');

function wpsm_register_options_page() {
    add_options_page('WP Stealth Mode Settings', 'WP Stealth Mode', 'manage_options', 'wpsm', 'wpsm_options_page');
}
add_action('admin_menu', 'wpsm_register_options_page');

