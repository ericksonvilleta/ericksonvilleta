// ========== CORE STEALTH FUNCTIONS ==========

remove_action('wp_head', 'wp_generator');
remove_action('wp_head', 'rest_output_link_wp_head', 10);
remove_action('wp_head', 'wp_oembed_add_discovery_links', 10);
remove_action('template_redirect', 'rest_output_link_header', 11, 0);
remove_action('wp_head', 'print_emoji_detection_script', 7);
remove_action('wp_print_styles', 'print_emoji_styles');
remove_action('wp_head', 'wlwmanifest_link');
remove_action('wp_head', 'rsd_link');
remove_action('wp_head', 'wp_shortlink_wp_head');
remove_action('wp_head', 'feed_links', 2);
remove_action('wp_head', 'feed_links_extra', 3);

add_action('wp_default_scripts', function ($scripts) {
    if (!is_admin() && isset($scripts->registered['jquery'])) {
        $script = $scripts->registered['jquery'];
        if ($script->deps) {
            $script->deps = array_diff($script->deps, ['jquery-migrate']);
        }
    }
});

add_filter('script_loader_src', function ($src) {
    return remove_query_arg('ver', $src);
}, 9999);

add_filter('style_loader_src', function ($src) {
    return remove_query_arg('ver', $src);
}, 9999);

// ========== CONDITIONAL FEATURE LOGIC ==========

if (get_option('wpsm_disable_feeds')) {
    add_action('do_feed', 'wpsm_disable_feeds_cb', 1);
    add_action('do_feed_rdf', 'wpsm_disable_feeds_cb', 1);
    add_action('do_feed_rss', 'wpsm_disable_feeds_cb', 1);
    add_action('do_feed_rss2', 'wpsm_disable_feeds_cb', 1);
    add_action('do_feed_atom', 'wpsm_disable_feeds_cb', 1);
    function wpsm_disable_feeds_cb() {
        wp_die(__('Feeds are disabled.'));
    }
}

if (get_option('wpsm_hide_login')) {
    add_action('init', function () {
        if (strpos($_SERVER['REQUEST_URI'], 'wp-login.php') !== false || strpos($_SERVER['REQUEST_URI'], 'wp-login') !== false) {
            wp_die('404 Not Found', 'Not Found', ['response' => 404]);
        }
    });
}

// Custom login URL routing
add_action('init', function () {
    $custom_slug = trim(get_option('wpsm_custom_login_slug'), '/');
    if (empty($custom_slug)) return;

    if (strpos($_SERVER['REQUEST_URI'], '/' . $custom_slug) !== false) {
        require_once ABSPATH . 'wp-login.php';
        exit;
    }
});

if (get_option('wpsm_obfuscate_dirs')) {
    add_filter('the_content', function ($content) {
        $content = str_replace('/wp-content/', '/assets/', $content);
        $content = str_replace('/wp-includes/', '/includes/', $content);
        return $content;
    });

    add_action('template_redirect', function () {
        ob_start(function ($buffer) {
            $buffer = str_replace('/wp-content/', '/assets/', $buffer);
            $buffer = str_replace('/wp-includes/', '/includes/', $buffer);
            return $buffer;
        });
    });
}

// ========== BLOCK SCANNING TOOLS ==========
add_action('init', function () {
    $block_agents = [
        'Wappalyzer', 'WPScan', 'BuiltWith', 'WhatRuns', 'nmap', 'netcraft', 'curl', 'python-requests', 'libwww-perl', 'nikto'
    ];
    $ua = $_SERVER['HTTP_USER_AGENT'] ?? '';
    foreach ($block_agents as $agent) {
        if (stripos($ua, $agent) !== false) {
            header('HTTP/1.1 403 Forbidden');
            exit('Access denied.');
        }
    }
});
